# DocMind Frontend Environment Variables
# Only VITE_ prefixed variables are exposed to the browser in Vite projects.

# Backend API base URL for document upload, listing, and Q&A queries.
# Default: http://127.0.0.1:8000 (local FastAPI dev server)
# Change this to your deployed backend URL for production.
VITE_DOCMIND_API_BASE=http://127.0.0.1:8000
